    },
    "price_per_message_credit": {
      "type": "number",
      "title": "Pre\u00e7o ao Cliente por Cr\u00e9dito de Mensagem (R$)"
    },
    "price_per_integration_credit": {
      "type": "number",
      "title": "Pre\u00e7o ao Cliente por Cr\u00e9dito de Integra\u00e7\u00e3o (R$)"
    },
    "cost_per_credit": {
      "type": "number",
      "title": "[Legado] Custo por Cr\u00e9dito (R$)"
    },
    "price_per_credit": {
      "type": "number",
      "title": "[Legado] Pre\u00e7o por Cr\u00e9dito (R$)"
    },
    "currency": {
      "type": "string",
      "title": "Moeda",
      "default": "BRL"
    }
  },
  "required": [],
