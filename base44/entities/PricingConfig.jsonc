      "type": "number",
      "title": "Cr\u00e9ditos de Integra\u00e7\u00f5es inclusos no Plano"
    },
    "message_share_percent": {
      "type": "number",
      "title": "% do Plano atribu\u00eddo a Mensagens (rateio)",
