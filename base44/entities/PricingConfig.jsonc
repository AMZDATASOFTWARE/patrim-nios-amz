  "name": "PricingConfig",
  "type": "object",
  "properties": {
    "plan_price": {
      "type": "number",
      "title": "Pre\u00e7o Mensal do Plano (R$)"
    },
    "plan_message_credits": {
      "type": "number",
      "title": "Cr\u00e9ditos de Mensagens inclusos no Plano"
    },
