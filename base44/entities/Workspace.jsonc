{
  "name": "Workspace",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Nome da Empresa / Conta"
    },
    "owner_email": {
      "type": "string",
      "title": "E-mail do Propriet\u00e1rio"
    },
    "plan": {
      "type": "string",
      "title": "Plano",
      "enum": [
        "starter",
        "professional",
        "enterprise"
      ]
    },
    "plan_expires_at": {
      "type": "string",
      "format": "date",
      "title": "Plano v\u00e1lido at\u00e9"
    },
    "plan_status": {
      "type": "string",
      "title": "Status do Plano",
      "enum": [
        "trial",
        "active",
        "suspended",
        "cancelled"
      ]
    },
    "trial_ends_at": {
      "type": "string",
      "format": "date",
      "title": "Trial encerra em"
    },
    "member_emails": {
      "type": "array",
      "title": "Membros",
      "items": {
        "type": "string"
      }
    },
    "logo_url": {
      "type": "string",
      "title": "Logo"
    },
    "cnpj": {
      "type": "string",
      "title": "CNPJ / CPF"
    },
    "phone": {
      "type": "string",
      "title": "Telefone"
    },
    "address": {
      "type": "string",
      "title": "Endere\u00e7o"
    }
  },
  "required": [
    "name",
    "owner_email",
    "plan"
  ],
  "rls": {
    "//": "RLS é row-level (não field-level): se o dono pudesse dar update na linha, poderia gravar plan/plan_status e burlar o paywall. Por isso create/update/delete só ocorrem via service-role (createWorkspace, inviteMember, notifyBilling, adminApi, updateWorkspaceProfile). Pelo SDK, apenas platform-admin. read continua liberado para dono e membros carregarem o próprio workspace.",
    "create": {
      "user_condition": {
        "is_platform_admin": true
      }
    },
    "read": {
      "$or": [
        {
          "data.owner_email": "{{user.email}}"
        },
        {
          "data.member_emails": {
            "$in": [
              "{{user.email}}"
            ]
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "is_platform_admin": true
      }
    },
    "delete": {
      "user_condition": {
        "is_platform_admin": true
      }
    }
  }
}